{
  "name": "memo",
  "version": "0.0.3",
  "description": "Memo Desktop Application",
  "desktopName": "Memo",
  "homepage": "https://memocash.github.io/desktop/",
  "main": "main/index.js",
  "repository": "github.com/memocash/desktop",
  "scripts": {
    "start": "electron .",
    "create": "npx electron-packager . Memo --overwrite --icon ./main/assets/memo-logo-small.icns --out dist",
    "build": "next build renderer",
    "pack-app": "npm run build && electron-builder --dir",
    "rebuild": "electron-rebuild",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "author": "Memo Technology, Inc.",
  "license": "Apache-2.0",
  "build": {
    "appId": "cash.memo.desktop",
    "productName": "Memo",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "copyright": "Copyright © Memo Technology, Inc.",
    "toolsets": {
      "appimage": "1.0.3"
    },
    "files": [
      "main/**/*",
      "build/icon.png",
      "renderer/out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "publish": null,
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Finance",
      "icon": "build/icon.png",
      "maintainer": "Memo Technology, Inc. <support@memo.cash>",
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "electron": "39.8.5",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.1",
    "next": "^15.5.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@bitcoin-dot-com/bitcoincashjs2-lib": "^4.1.0",
    "better-sqlite3": "^12.11.1",
    "bip32": "^5.0.1",
    "bip39": "^3.0.4",
    "crypto-js": "^4.2.0",
    "electron-is-dev": "^2.0.0",
    "electron-next": "^3.1.5",
    "electron-serve": "^1.3.0",
    "node-gyp": "^13.0.1",
    "react-icons": "^4.4.0",
    "react-linkify": "^1.0.0-alpha",
    "tiny-secp256k1": "^2.2.4",
    "ws": "^8.21.0"
  },
  "overrides": {
    "linkify-it": "^5.0.2",
    "postcss": "^8.5.19"
  },
  "trustedDependencies": [
    "electron"
  ]
}
