  "license": "Apache-2.0",
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "electron": "39.8.5",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.1",
    "next": "^15.5.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@bitcoin-dot-com/bitcoincashjs2-lib": "^4.1.0",
    "better-sqlite3": "^12.11.1",
    "bip32": "^5.0.1",
    "bip39": "^3.0.4",
    "crypto-js": "^4.2.0",
    "electron-is-dev": "^2.0.0",
    "electron-next": "^3.1.5",
    "node-gyp": "^13.0.1",
    "react-icons": "^4.4.0",
    "react-linkify": "^1.0.0-alpha",
